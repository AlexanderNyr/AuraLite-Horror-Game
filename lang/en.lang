end.title = The Valley Remembers
end.text = After nine days the fog feels\nlike an old friend.\nYou leave the valley changed,\nbut at peace.

gameover.title = The Fog Took You
gameover.text = Something in the mist found you.\nTry to stay farther from the shadows.
gameover.restart = Press ACTION to return to menu

